FROM node:24-alpine

WORKDIR /app

# Copy root package files
COPY package*.json ./
# Copy shared and frontend package files to mirrored structure
COPY shared/package*.json ./shared/
COPY frontend/package*.json ./frontend/

# Install all dependencies (including dev dependencies) from root
RUN npm install

# Copy source code (respecting structure)
COPY shared/ ./shared/
COPY frontend/ ./frontend/

EXPOSE 3000

# Run from root using workspace flag
CMD ["npm", "run", "dev", "-w", "frontend"]