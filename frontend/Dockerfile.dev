FROM node:24-alpine

WORKDIR /app

# Copy root package files
COPY package*.json ./
# Copy all package files for all workspaces to ensure complete dependency graph
COPY shared/package*.json ./shared/
COPY frontend/package*.json ./frontend/
COPY services/canvas-service/package*.json ./services/canvas-service/
COPY services/room-service/package*.json ./services/room-service/

# Install all dependencies (including dev dependencies) from root
RUN npm install

# Copy source code (respecting structure)
COPY shared/ ./shared/
COPY frontend/ ./frontend/

EXPOSE 3000

# Run from root using workspace flag
CMD ["npm", "run", "dev", "-w", "frontend"]