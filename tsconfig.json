{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "resolveJsonModule": true,
    "incremental": true,
    "composite": true,
    "downlevelIteration": true,
    "baseUrl": ".",
    "paths": {
      "@coffee-canvas/shared": ["shared/dist/index.js"],
      "@coffee-canvas/shared/*": ["shared/dist/*"]
    }
  },
  "references": [
    { "path": "./shared" },
    { "path": "./services/canvas-service" },
    { "path": "./services/room-service" },
    { "path": "./frontend" }
  ],
  "files": []
}
