{
  "extends": "../../shared/tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "baseUrl": "./src",
    "composite": true,
    "target": "ES2020", // Explicitly set for this service
    "downlevelIteration": true, // Specifically fixes the Map/Set iteration error
    "paths": {
      "@shared/*": ["../../shared/src/*"]
    }
  },
  "references": [{ "path": "../../shared" }],
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "**/*.test.ts"]
}
