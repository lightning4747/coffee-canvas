FROM node:24-alpine

WORKDIR /app

# Copy root package files
COPY package*.json ./
# Copy shared and service package files to mirrored structure
COPY shared/package*.json ./shared/
COPY services/room-service/package*.json ./services/room-service/

# Install all dependencies (including dev dependencies) from root
RUN npm install

# Copy source code (respecting structure)
COPY shared/ ./shared/
COPY services/room-service/ ./services/room-service/

EXPOSE 3002

# Run from root using workspace flag
CMD ["npm", "run", "dev", "-w", "services/room-service"]