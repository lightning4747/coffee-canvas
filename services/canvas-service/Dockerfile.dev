FROM node:24-alpine

WORKDIR /app

# Copy root package files
COPY package*.json ./
# Copy shared and service package files to mirrored structure
COPY shared/package*.json ./shared/
COPY services/canvas-service/package*.json ./services/canvas-service/

# Install all dependencies (including dev dependencies) from root
RUN npm install

# Copy source code (respecting structure)
COPY shared/ ./shared/
COPY services/canvas-service/ ./services/canvas-service/

EXPOSE 3001

# Run from root using workspace flag
CMD ["npm", "run", "dev", "-w", "services/canvas-service"]