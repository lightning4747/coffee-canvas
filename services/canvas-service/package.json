{
  "name": "@coffee-canvas/canvas-service",
  "version": "1.0.0",
  "description": "Canvas Service for real-time drawing operations",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon -L --watch src -e ts,js --exec ts-node -r tsconfig-paths/register src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "jest --passWithNoTests",
    "test:ci": "npm run test",
    "test:resilience": "jest src/__tests__/resilience.integration.test.ts",
    "lint": "eslint src/**/*.ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@coffee-canvas/shared": "file:../../shared",
    "@grpc/grpc-js": "^1.9.0",
    "@grpc/proto-loader": "^0.7.0",
    "@prisma/client": "^5.0.0",
    "compression": "^1.8.1",
    "cors": "^2.8.0",
    "express": "^4.18.0",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.0",
    "opossum": "^9.0.0",
    "prisma": "^5.0.0",
    "prom-client": "^15.1.3",
    "rate-limiter-flexible": "^3.0.0",
    "redis": "^4.6.0",
    "socket.io": "^4.7.0",
    "socket.io-redis": "^6.1.0",
    "uuid": "^9.0.1",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.0",
    "@types/express": "^4.17.0",
    "@types/jest": "^29.0.0",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/node": "^24.0.0",
    "@types/opossum": "^8.1.9",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.0.0",
    "fast-check": "^4.6.0",
    "jest": "^29.0.0",
    "nodemon": "^3.0.0",
    "ts-jest": "^29.0.0",
    "ts-node": "^10.9.0",
    "tsconfig-paths": "^3.15.0",
    "typescript": "^5.3.0"
  }
}
